# .env.beta
ENVIRONMENT=beta

# Database - Beta server (PostgreSQL)
PG_HOST=beta-db.kila.com
PG_PORT=5432
PG_USER=beta_user
PG_PASSWORD=beta_secure_password_from_vault
PG_DATABASE=ai_prompts_beta

# AI Model
ANTHROPIC_API_KEY=sk-ant-beta-key-here
AI_MODEL=claude-sonnet-4-5-20250929

# Security - Real secret from secrets manager
SECRET_KEY=beta-secret-key-from-aws-secrets-manager

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=["https://beta.yourapp.com","https://staging.yourapp.com"]
